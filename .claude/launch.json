{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ai-service",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--reload", "--host", "127.0.0.1", "--port", "8001"],
      "port": 8001,
      "env": {
        "DEV_MODE": "true",
        "JWT_SECRET": "dev-jwt-secret-32-chars-long-yes-yes",

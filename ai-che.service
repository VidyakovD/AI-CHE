[Unit]
Description=AI Che FastAPI Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/AI-CHE
Environment="PYTHONUNBUFFERED=1"
ExecStart=/root/AI-CHE/venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8000 --workers 4
Restart=always
RestartSec=3
LimitNOFILE=65536
StandardOutput=journal
StandardError=journal
# Для безопасности: рекомендуется создать пользователя aiche и раскомментить:
# User=aiche
# Group=aiche

[Install]
WantedBy=multi-user.target

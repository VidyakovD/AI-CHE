# ── AI Keys (comma-separated for multiple) ────────────────────────
OPENAI_API_KEYS=sk-proj-...
ANTHROPIC_API_KEYS=sk-ant-api03-...
# Если используется прокси (например awstore.cloud) — задай:
# ANTHROPIC_BASE_URL=https://api.awstore.cloud
PERPLEXITY_API_KEYS=pplx-...
GROK_API_KEYS=xai-...
KLING_API_KEYS=...
GOOGLE_API_KEYS=AIzaSyAIHS_VwqktPJn3pO5CrDB...

# ── Veo (Google Cloud) ─────────────────────────────────────────
VEO_PROJECT_ID=your-gcp-project-id

# ── YooKassa ──────────────────────────────────────────────────────
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=test_...

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string

# ── Yandex.Disk Backup ───────────────────────────────────────────
# OAuth token from https://oauth.yandex.ru/
# Scopes: cloud_api:disk.upload
YAD_TOKEN=

# ── Email (SMTP) ──────────────────────────────────────────────────
# Если не задан SMTP_HOST — письма логируются в консоль (dev режим)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Obsidian AI <you@gmail.com>

# ── App ───────────────────────────────────────────────────────────
APP_URL=https://yourdomain.com

# ── Deploy ────────────────────────────────────────────────────────
DEPLOY_TOKEN=change_me_to_random_string

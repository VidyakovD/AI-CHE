# ── AI Keys (comma-separated for multiple) ────────────────────────
OPENAI_API_KEYS=sk-proj-...
ANTHROPIC_API_KEYS=sk-ant-api03-...
# Если используется прокси (например awstore.cloud) — задай:
# ANTHROPIC_BASE_URL=https://api.awstore.cloud
PERPLEXITY_API_KEYS=pplx-...
GROK_API_KEYS=xai-...
KLING_API_KEYS=...
GOOGLE_API_KEYS=AIzaSyAIHS_VwqktPJn3pO5CrDB...

# ── Veo (Google Cloud) ─────────────────────────────────────────
VEO_PROJECT_ID=your-gcp-project-id

# ── YooKassa ──────────────────────────────────────────────────────
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=test_...

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
# Старые JWT_SECRET'ы через запятую — для расшифровки старых IMAP-паролей
# после ротации ключа. После вызова /admin/reencrypt-secrets можно удалить.
LEGACY_JWT_SECRETS=

# ── Yandex.Disk Backup ───────────────────────────────────────────
# OAuth token from https://oauth.yandex.ru/
# Scopes: cloud_api:disk.upload
YAD_TOKEN=

# ── Email (SMTP) ──────────────────────────────────────────────────
# Если не задан SMTP_HOST — письма логируются в консоль (dev режим)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Obsidian AI <you@gmail.com>

# ── App ───────────────────────────────────────────────────────────
APP_URL=https://yourdomain.com

# ── CORS (comma-separated origins, required for production) ──────
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Admin ─────────────────────────────────────────────────────────
# ADMIN_EMAILS — список через запятую, кто видит /admin.html
# ADMIN_EMAIL/ADMIN_PASSWORD — учётка для create_admin.py (single)
ADMIN_EMAILS=admin@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=

# ── Trusted proxies (для X-Forwarded-For в rate-limit) ───────────
# Список IP откуда приходят запросы за прокси. По умолчанию: 127.0.0.1,::1
# Пример для Cloudflare: 173.245.48.0/20,103.21.244.0/22,...
TRUSTED_PROXIES=127.0.0.1,::1

# ── Dev mode (CORS) ──────────────────────────────────────────────
# В проде НЕ ВКЛЮЧАЙТЕ. Локально позволяет запускать без ALLOWED_ORIGINS
DEV_MODE=false

# ── Python sandbox в воркфлоу ботов ──────────────────────────────
# По умолчанию выключен — exec() небезопасен. Включайте только если
# понимаете риски (RCE-вектор от владельцев ботов).
ENABLE_PYTHON_SANDBOX=false

# ── Deploy ────────────────────────────────────────────────────────
DEPLOY_TOKEN=change_me_to_random_string

# ── Anthropic Proxy (optional) ───────────────────────────────────
# PROXY_TOKEN=change_me_for_proxy_auth

# ── Bonuses (уменьшение дефолтов — анти-фрод) ────────────────────
# Раньше было 5000 и 10000 — легко накрутить через массовые регистрации
WELCOME_BONUS_CH=500        # приветственный при верификации email
REFERRAL_SIGNUP_BONUS=1000  # при регистрации друга по реф-коду
